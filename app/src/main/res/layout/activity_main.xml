<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_background"
    android:fitsSystemWindows="true">

    <!-- Main Home Screen -->
    <LinearLayout
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/terminal_background"
        android:padding="16dp">

        <!-- Top Bar with Theme Toggle Switch -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ init theme"
                android:textColor="@color/terminal_comment"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/themeToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:thumbTint="@android:color/white"
                app:trackTint="@color/switch_track_tint" />

        </RelativeLayout>

        <!-- Terminal Clock Widget -->
        <androidx.cardview.widget.CardView
            android:id="@+id/clockCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/terminal_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            android:foreground="?android:attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ date"
                    android:textColor="@color/terminal_comment"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/timeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text="00:00:00"
                    android:textColor="@color/terminal_string"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/dateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:text="Mon Jun 30 2024"
                    android:textColor="@color/terminal_variable"
                    android:textSize="14sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Horizontal Container for Screen Time & Battery Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:baselineAligned="false">

            <!-- Merged Screen Time Widget -->
            <androidx.cardview.widget.CardView
                android:id="@+id/screenTimeCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:minHeight="160dp"
                app:cardBackgroundColor="@color/terminal_card_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="$ screen"
                            android:textColor="@color/terminal_comment"
                            android:textSize="12sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/setGoals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="[set]"
                            android:textColor="@color/terminal_function"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:padding="4dp"
                            android:background="?android:attr/selectableItemBackground" />

                        <TextView
                            android:id="@+id/permissionStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="[grant]"
                            android:textColor="@color/terminal_error"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:padding="4dp"
                            android:background="?android:attr/selectableItemBackground"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Tab Headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/todayTab"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="[today]"
                            android:textColor="@color/terminal_function"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:padding="2dp"
                            android:gravity="center"
                            android:background="?android:attr/selectableItemBackground" />

                        <TextView
                            android:id="@+id/weekTab"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="[week]"
                            android:textColor="@color/terminal_comment"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:padding="2dp"
                            android:gravity="center"
                            android:background="?android:attr/selectableItemBackground" />

                    </LinearLayout>

                    <!-- Screen Time Content -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/screenTimeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="0h 0m today"
                            android:textColor="@color/terminal_number"
                            android:textSize="15sp" />

                        <!-- Merged Limit Goal and Progress % -->
                        <TextView
                            android:id="@+id/screenTimeGoalLimitText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="monospace"
                            android:text="limit: 4h 0m [0%]"
                            android:textColor="@color/terminal_string"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/goalStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="monospace"
                            android:text="on track"
                            android:textColor="@color/terminal_comment"
                            android:textSize="10sp"
                            android:alpha="0.8" />

                        <TextView
                            android:id="@+id/screenTimeDetails"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="avg: 0h 0m"
                            android:textColor="@color/terminal_comment"
                            android:textSize="10sp"
                            android:visibility="gone" />

                        <!-- Align updated time at the very bottom -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/lastUpdated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="updated: now"
                            android:textColor="@color/terminal_comment"
                            android:textSize="9sp"
                            android:alpha="0.6" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Battery Information Widget -->
            <androidx.cardview.widget.CardView
                android:id="@+id/batteryCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:minHeight="160dp"
                app:cardBackgroundColor="@color/terminal_card_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ battery"
                        android:textColor="@color/terminal_comment"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/batteryLevelText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="--% (status)"
                            android:textColor="@color/terminal_variable"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/batteryTempText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="monospace"
                            android:text="temp: --°C"
                            android:textColor="@color/terminal_comment"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/batteryHealthText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="monospace"
                            android:text="health: --"
                            android:textColor="@color/terminal_comment"
                            android:textSize="10sp"
                            android:alpha="0.8" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Home Apps Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/terminal_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="$ ls ~/apps | head -n∞"
                        android:textColor="@color/terminal_comment"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/customizeApps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="[edit]"
                        android:textColor="@color/terminal_function"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:padding="4dp"
                        android:background="?android:attr/selectableItemBackground" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/homeAppsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="ifContentScrolls" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Swipe Left Indicator -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="← swipe left for apps | swipe right for camera →"
            android:textColor="@color/terminal_comment"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:alpha="0.7" />

    </LinearLayout>

    <!-- App Drawer Bottom Sheet -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/appDrawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/terminal_background"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/terminal_background"
            android:padding="16dp">

            <!-- App Drawer Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="$ find /system/apps -type f"
                    android:textColor="@color/terminal_comment"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/closeDrawer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[x]"
                    android:textColor="@color/terminal_error"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:background="?android:attr/selectableItemBackground" />

            </LinearLayout>

            <!-- All Apps List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/allAppsRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
