<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Main Home Screen -->
    <LinearLayout
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/black"
        android:padding="16dp">

        <!-- Terminal Clock Widget -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/terminal_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ date"
                    android:textColor="@color/terminal_comment"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/timeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text="20:26:45"
                    android:textColor="@color/terminal_string"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/dateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:text="Mon Jun 30 2024"
                    android:textColor="@color/terminal_variable"
                    android:textSize="14sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Screen Time Widget with Tabs -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/terminal_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="$ screen --time"
                        android:textColor="@color/terminal_comment"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/permissionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="[grant]"
                        android:textColor="@color/terminal_error"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:padding="4dp"
                        android:background="?android:attr/selectableItemBackground"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Tab Headers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/todayTab"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="[today]"
                        android:textColor="@color/terminal_function"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:padding="4dp"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/weekTab"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="[week]"
                        android:textColor="@color/terminal_comment"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:padding="4dp"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground" />

                </LinearLayout>

                <!-- Screen Time Content -->
                <LinearLayout
                    android:id="@+id/screenTimeContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/screenTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="2h 34m today"
                        android:textColor="@color/terminal_number"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/screenTimeDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:text="avg: 3h 12m"
                        android:textColor="@color/terminal_comment"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/lastUpdated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:text="updated: now"
                        android:textColor="@color/terminal_comment"
                        android:textSize="10sp"
                        android:alpha="0.7" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Screen Time Goals Widget -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/terminal_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="$ screen --limits"
                        android:textColor="@color/terminal_comment"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/setGoals"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="[set]"
                        android:textColor="@color/terminal_function"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:padding="4dp"
                        android:background="?android:attr/selectableItemBackground" />

                </LinearLayout>

                <!-- Goals Content -->
                <LinearLayout
                    android:id="@+id/goalsContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <!-- Daily Goal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="daily:"
                            android:textColor="@color/terminal_variable"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/dailyGoalText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="4h 0m"
                            android:textColor="@color/terminal_string"
                            android:textSize="14sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/dailyProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="[58%]"
                            android:textColor="@color/terminal_number"
                            android:textSize="12sp"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <!-- Weekly Goal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="weekly:"
                            android:textColor="@color/terminal_variable"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/weeklyGoalText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="25h 0m"
                            android:textColor="@color/terminal_string"
                            android:textSize="14sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/weeklyProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="[42%]"
                            android:textColor="@color/terminal_number"
                            android:textSize="12sp"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <!-- Status Message -->
                    <TextView
                        android:id="@+id/goalStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="on track for today"
                        android:textColor="@color/terminal_comment"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:alpha="0.8" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Home Apps Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/terminal_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="$ ls ~/apps | head -n∞"
                        android:textColor="@color/terminal_comment"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/customizeApps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="[edit]"
                        android:textColor="@color/terminal_function"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:padding="4dp"
                        android:background="?android:attr/selectableItemBackground" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/homeAppsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="ifContentScrolls" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Swipe Left Indicator -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="← swipe left for app drawer (or long press)"
            android:textColor="@color/terminal_comment"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:alpha="0.7" />

    </LinearLayout>

    <!-- App Drawer Bottom Sheet -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/appDrawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/black"
            android:padding="16dp">

            <!-- App Drawer Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="$ find /system/apps -type f"
                    android:textColor="@color/terminal_comment"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/closeDrawer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[x]"
                    android:textColor="@color/terminal_error"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:background="?android:attr/selectableItemBackground" />

            </LinearLayout>

            <!-- All Apps List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/allAppsRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
